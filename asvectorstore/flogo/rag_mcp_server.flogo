{
  "imports": [
    "github.com/project-flogo/flow",
    "github.com/project-flogo/contrib/activity/noop",
    "github.com/mbloomfi-tibco/extensions/ollama/activity/generateEmbedding",
    "github.com/tibco/flogo-general/src/app/General/activity/parsejson",
    "github.com/tibco/flogo-general/src/app/General/activity/rest",
    "github.com/tibco/flogo-general/src/app/General/activity/actreply",
    "github.com/tibco/flogo-files/src/app/File/activity/read",
    "github.com/tibco/flogo-mcp/src/app/MCP/trigger/mcpserver",
    "github.com/project-flogo/contrib/function/array",
    "git.tibco.com/git/product/ipaas/wi-contrib.git/function/boolean",
    "git.tibco.com/git/product/ipaas/wi-contrib.git/function/utility",
    "github.com/project-flogo/contrib/function/coerce",
    "github.com/project-flogo/contrib/function/string"
  ],
  "name": "rag_mcp_server",
  "description": "Add description",
  "version": "1.0.0",
  "type": "flogo:app",
  "appModel": "1.1.1",
  "tags": [],
  "triggers": [
    {
      "ref": "#mcpserver",
      "name": "flogo-mcp-mcpsever",
      "description": "Flogo MCP server for Agentic AI",
      "settings": {
        "serverName": "rag_mcp_server",
        "serverVersion": "1.0.0",
        "serverType": "HTTP",
        "serverPort": "8091"
      },
      "id": "MCPServer",
      "handlers": [
        {
          "description": "",
          "settings": {
            "handlerType": "Tool",
            "handlerName": "customer_information_similarity_search",
            "handlerDescription": "Searches a data store of company information consisting of text chunks and associated metadata that are semantically similar to the input string. \n\nData is returned in a JSON structure, including an array named 'documents', which contains an array of markdown text for each document chunk, \nand an array named 'metadatas' which contains an array of the meta data properties related to the chunk. \n\nThe items in the lists are aligned by index. For example, to find the metadata associated with document chunk with index 3, you lookup the metadatas array with index 3.\n\nThe company name can be found in the \"Header 1\" and \"source\" metadata items. \n\nNEVER use data from chunks where the 'Header 1' metadata shows the wrong company name.\nNEVER assume that there may be a misalignment between the document and metadatas structures.",
            "resourceUri": ""
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:Perform_Search"
            },
            "input": {
              "arguments": "=$.arguments"
            },
            "output": {
              "response": {
                "mapping": {
                  "data": "=$.response.data"
                }
              }
            }
          },
          "schemas": {
            "reply": {
              "toolResult": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  }\r\n}"
              },
              "promptResult": {
                "type": "json",
                "value": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"description\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"messages\": {\r\n      \"type\": \"array\",\r\n      \"items\": \r\n        {\r\n          \"type\": \"object\",\r\n          \"properties\": {\r\n            \"role\": {\r\n              \"type\": \"string\"\r\n            },\r\n            \"content\": {\r\n              \"type\": \"string\"\r\n            }\r\n          },\r\n          \"required\": [\r\n            \"role\",\r\n            \"content\"\r\n          ]\r\n        }\r\n    },\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"description\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"messages\": {\r\n      \"type\": \"array\",\r\n      \"items\": \r\n        {\r\n          \"type\": \"object\",\r\n          \"properties\": {\r\n            \"role\": {\r\n              \"type\": \"string\"\r\n            },\r\n            \"content\": {\r\n              \"type\": \"string\"\r\n            }\r\n          },\r\n          \"required\": [\r\n            \"role\",\r\n            \"content\"\r\n          ]\r\n        }\r\n    },\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              },
              "resourceResult": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n    \"properties\": {\r\n        \"textResourceContents\": {\r\n            \"type\": \"array\",\r\n            \"items\": {\r\n                \"type\": \"object\",\r\n                \"properties\": {\r\n                    \"uri\": {\r\n                        \"type\": \"string\"\r\n                    },\r\n                    \"text\": {\r\n                        \"type\": \"string\"\r\n                    },\r\n                    \"mimeType\": {\r\n                        \"type\": \"string\"\r\n                    }\r\n                },\r\n                \"required\": [\r\n                    \"text\",\r\n                    \"mimeType\"\r\n                ]\r\n            }\r\n        },\r\n        \"success\": {\r\n            \"type\": \"boolean\"\r\n        },\r\n        \"error\": {\r\n            \"type\": \"string\"\r\n        }\r\n    }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n    \"properties\": {\r\n        \"textResourceContents\": {\r\n            \"type\": \"array\",\r\n            \"items\": {\r\n                \"type\": \"object\",\r\n                \"properties\": {\r\n                    \"uri\": {\r\n                        \"type\": \"string\"\r\n                    },\r\n                    \"text\": {\r\n                        \"type\": \"string\"\r\n                    },\r\n                    \"mimeType\": {\r\n                        \"type\": \"string\"\r\n                    }\r\n                },\r\n                \"required\": [\r\n                    \"text\",\r\n                    \"mimeType\"\r\n                ]\r\n            }\r\n        },\r\n        \"success\": {\r\n            \"type\": \"boolean\"\r\n        },\r\n        \"error\": {\r\n            \"type\": \"string\"\r\n        }\r\n    }\r\n}"
              }
            },
            "output": {
              "arguments": "schema://SimilaritySearchInput"
            }
          },
          "name": "Perform_Search"
        },
        {
          "description": "",
          "settings": {
            "handlerType": "Tool",
            "handlerName": "file_load_company_description",
            "handlerDescription": "Loads a markdown document that contains a comprehensive company overview",
            "resourceUri": ""
          },
          "action": {
            "ref": "github.com/project-flogo/flow",
            "settings": {
              "flowURI": "res://flow:Read_Company_Description_Document"
            },
            "input": {
              "file_path": "=$.arguments.file_path"
            },
            "output": {
              "response": {
                "mapping": {
                  "data": "=$.file_content"
                }
              }
            }
          },
          "schemas": {
            "reply": {
              "toolResult": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n  \"properties\": {\r\n    \"data\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    }\r\n  }\r\n}"
              },
              "promptResult": {
                "type": "json",
                "value": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"description\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"messages\": {\r\n      \"type\": \"array\",\r\n      \"items\": \r\n        {\r\n          \"type\": \"object\",\r\n          \"properties\": {\r\n            \"role\": {\r\n              \"type\": \"string\"\r\n            },\r\n            \"content\": {\r\n              \"type\": \"string\"\r\n            }\r\n          },\r\n          \"required\": [\r\n            \"role\",\r\n            \"content\"\r\n          ]\r\n        }\r\n    },\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}",
                "fe_metadata": "{\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"description\": {\r\n      \"type\": \"string\"\r\n    },\r\n    \"messages\": {\r\n      \"type\": \"array\",\r\n      \"items\": \r\n        {\r\n          \"type\": \"object\",\r\n          \"properties\": {\r\n            \"role\": {\r\n              \"type\": \"string\"\r\n            },\r\n            \"content\": {\r\n              \"type\": \"string\"\r\n            }\r\n          },\r\n          \"required\": [\r\n            \"role\",\r\n            \"content\"\r\n          ]\r\n        }\r\n    },\r\n    \"success\": {\r\n      \"type\": \"boolean\"\r\n    },\r\n    \"error\": {\r\n      \"type\": \"string\"\r\n    }\r\n  }\r\n}"
              },
              "resourceResult": {
                "type": "json",
                "value": "{\r\n    \"type\": \"object\",\r\n    \"properties\": {\r\n        \"textResourceContents\": {\r\n            \"type\": \"array\",\r\n            \"items\": {\r\n                \"type\": \"object\",\r\n                \"properties\": {\r\n                    \"uri\": {\r\n                        \"type\": \"string\"\r\n                    },\r\n                    \"text\": {\r\n                        \"type\": \"string\"\r\n                    },\r\n                    \"mimeType\": {\r\n                        \"type\": \"string\"\r\n                    }\r\n                },\r\n                \"required\": [\r\n                    \"text\",\r\n                    \"mimeType\"\r\n                ]\r\n            }\r\n        },\r\n        \"success\": {\r\n            \"type\": \"boolean\"\r\n        },\r\n        \"error\": {\r\n            \"type\": \"string\"\r\n        }\r\n    }\r\n}",
                "fe_metadata": "{\r\n    \"type\": \"object\",\r\n    \"properties\": {\r\n        \"textResourceContents\": {\r\n            \"type\": \"array\",\r\n            \"items\": {\r\n                \"type\": \"object\",\r\n                \"properties\": {\r\n                    \"uri\": {\r\n                        \"type\": \"string\"\r\n                    },\r\n                    \"text\": {\r\n                        \"type\": \"string\"\r\n                    },\r\n                    \"mimeType\": {\r\n                        \"type\": \"string\"\r\n                    }\r\n                },\r\n                \"required\": [\r\n                    \"text\",\r\n                    \"mimeType\"\r\n                ]\r\n            }\r\n        },\r\n        \"success\": {\r\n            \"type\": \"boolean\"\r\n        },\r\n        \"error\": {\r\n            \"type\": \"string\"\r\n        }\r\n    }\r\n}"
              }
            },
            "output": {
              "arguments": {
                "type": "json",
                "value": "{\r\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\r\n  \"title\": \"MarkdownDocumentInput\",\r\n  \"description\": \"Defines the input for retrieving a markdown document.\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"file_path\": {\r\n      \"description\": \"The full file system path to the .md document to retrieve.\",\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"file_path\"\r\n  ],\r\n  \"additionalProperties\": false\r\n}",
                "fe_metadata": "{\r\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\r\n  \"title\": \"MarkdownDocumentInput\",\r\n  \"description\": \"Defines the input for retrieving a markdown document.\",\r\n  \"type\": \"object\",\r\n  \"properties\": {\r\n    \"file_path\": {\r\n      \"description\": \"The full file system path to the .md document to retrieve.\",\r\n      \"type\": \"string\"\r\n    }\r\n  },\r\n  \"required\": [\r\n    \"file_path\"\r\n  ],\r\n  \"additionalProperties\": false\r\n}"
              }
            }
          },
          "name": "Read_Company_Description_Document"
        }
      ]
    }
  ],
  "resources": [
    {
      "id": "flow:Perform_Search",
      "data": {
        "name": "Perform Search",
        "description": "",
        "links": [
          {
            "id": 1,
            "from": "StartActivity",
            "to": "GenerateEmbedding",
            "type": "label",
            "label": "StartActivity to GenerateEmbedding"
          },
          {
            "id": 2,
            "from": "GenerateEmbedding",
            "to": "ParseJSON",
            "type": "label",
            "label": "GenerateEmbedding to ParseJSON"
          },
          {
            "id": 3,
            "from": "ParseJSON",
            "to": "QueryChromaREST",
            "type": "label",
            "label": "ParseJSON to InvokeRESTService"
          },
          {
            "id": 4,
            "from": "QueryChromaREST",
            "to": "ReplyToTrigger",
            "type": "label",
            "label": "InvokeRESTService to ReplyToTrigger"
          },
          {
            "id": 5,
            "from": "QueryChromaREST",
            "to": "ReplyWithError",
            "type": "error",
            "label": "InvokeRESTService to ReplyToTrigger1"
          }
        ],
        "tasks": [
          {
            "id": "StartActivity",
            "name": "StartActivity",
            "description": "NoOp Activity",
            "activity": {
              "ref": "#noop"
            }
          },
          {
            "id": "GenerateEmbedding",
            "name": "GenerateEmbedding",
            "description": "Generates embedings ollama embedding API",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#generateEmbedding",
              "settings": {
                "ollamaHostURL": "=$property[\"OLLAMA_BASE_URL\"]",
                "embeddingModel": "nomic-embed-text",
                "embeddingModelVersion": "latest",
                "truncate": false,
                "keepAlive": 5
              },
              "input": {
                "embeddingText": "=$flow.arguments.query_text",
                "modelOptions": ""
              },
              "output": {
                "embedding": {
                  "schema": {
                    "type": "string"
                  }
                }
              }
            }
          },
          {
            "id": "ParseJSON",
            "name": "ParseJSON",
            "description": "Parses JSON string into JSON object",
            "activity": {
              "ref": "#parsejson",
              "input": {
                "validate": false,
                "jsonString": "=$activity[GenerateEmbedding].embedding"
              }
            }
          },
          {
            "id": "QueryChromaREST",
            "name": "QueryChromaREST",
            "description": "Simple REST Activity",
            "settings": {
              "retryOnError": {
                "count": 0,
                "interval": 0
              }
            },
            "activity": {
              "ref": "#rest",
              "input": {
                "enableASR": false,
                "swagger": "spec://3b7426cf",
                "authorization": false,
                "serviceName": "",
                "resourcePath": "/api/v2/tenants/{tenant}/databases/{database}/collections/{collection_id}/query",
                "Method": "POST",
                "Uri": "=$property[\"CHROMA_URL\"]",
                "requestType": "application/json",
                "Use certificate for verification": false,
                "mutualAuth": false,
                "Client Certificate": "",
                "Client Key": "",
                "Server Certificate": "",
                "disableSSLVerification": false,
                "disableKeepAlives": false,
                "followRedirects": true,
                "Timeout": 0,
                "proxy": "",
                "host": "",
                "pathParams": {
                  "mapping": {
                    "collection_id": "=$property[\"CHROMA_COLLECTION_ID\"]",
                    "tenant": "=$property[\"CHROMA_TENANT\"]",
                    "database": "=$property[\"CHROMA_DATABASE\"]"
                  }
                },
                "body": {
                  "mapping": {
                    "n_results": 10,
                    "query_embeddings": [
                      "=$activity[ParseJSON].jsonObject"
                    ],
                    "include": [
                      "documents",
                      "metadatas",
                      "distances"
                    ]
                  }
                }
              },
              "output": {
                "configureResponseCodes": true,
                "throwError": true,
                "responseType": "application/json",
                "responseOutput": "JSON Object"
              },
              "schemas": {
                "input": {
                  "serviceMetadata": {
                    "type": "json",
                    "value": "{\"$schema\":\"http://json-schema.org/draft-04/schema#\",\"type\":\"object\",\"properties\":{\"openapi\":{\"type\":\"string\"},\"info\":{\"type\":\"object\",\"properties\":{\"title\":{\"type\":\"string\"},\"description\":{\"type\":\"string\"},\"license\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"}}},\"version\":{\"type\":\"string\"}}},\"paths\":{\"type\":\"object\",\"properties\":{\"/api/v2/auth/identity\":{\"type\":\"object\",\"properties\":{\"get\":{\"type\":\"object\",\"properties\":{\"tags\":{\"type\":\"array\",\"items\":{}},\"summary\":{\"type\":\"string\"},\"operationId\":{\"type\":\"string\"},\"responses\":{\"type\":\"object\",\"properties\":{\"200\":{\"type\":\"object\",\"properties\":{\"description\":{\"type\":\"string\"},\"content\":{\"type\":\"object\",\"properties\":{\"application/json\":{\"type\":\"object\",\"properties\":{\"schema\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"required\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"properties\":{\"type\":\"object\",\"properties\":{\"databases\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"items\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}}}},\"tenant\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}},\"user_id\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}}}}}}}}}}}},\"500\":{\"type\":\"object\",\"properties\":{\"description\":{\"type\":\"string\"},\"content\":{\"type\":\"object\",\"properties\":{\"application/json\":{\"type\":\"object\",\"properties\":{\"schema\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"required\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"properties\":{\"type\":\"object\",\"properties\":{\"error\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}},\"message\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}}}}}}}}}}}}}}}}}},\"/api/v2/collections/{crn}\":{\"type\":\"object\",\"properties\":{\"get\":{\"type\":\"object\",\"properties\":{\"tags\":{\"type\":\"array\",\"items\":{}},\"summary\":{\"type\":\"string\"},\"operationId\":{\"type\":\"string\"},\"parameters\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"},\"in\":{\"type\":\"string\"},\"description\":{\"type\":\"string\"},\"required\":{\"type\":\"boolean\"},\"schema\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"}}}}}},\"responses\":{\"type\":\"object\",\"properties\":{\"200\":{\"type\":\"object\",\"properties\":{\"description\":{\"type\":\"string\"},\"content\":{\"type\":\"object\",\"properties\":{\"application/json\":{\"type\":\"object\",\"properties\":{\"schema\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"required\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"properties\":{\"type\":\"object\",\"properties\":{\"configuration_json\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"properties\":{\"type\":\"object\",\"properties\":{\"embedding_function\":{\"type\":\"object\",\"properties\":{\"oneOf\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"oneOf\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"required\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"properties\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"enum\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}}}}}},\"allOf\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"required\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"properties\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"object\",\"properties\":{\"type\":{\"type\":\"string\"},\"enum\":{\"type\":\"array\",\"items\":{\"type\":\"